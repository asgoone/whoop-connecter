# WHOOP OAuth credentials — from developer.whoop.com
WHOOP_CLIENT_ID=your_client_id_here
WHOOP_CLIENT_SECRET=your_client_secret_here

# Encryption key for token storage (generate: python3 -c "import secrets; print(secrets.token_hex(32))")
WHOOP_TOKEN_ENCRYPTION_KEY=your_64_char_hex_key_here

# Optional settings
WHOOP_REDIRECT_URI=http://localhost:8080/callback
WHOOP_TOKEN_PATH=~/.whoop/tokens.enc
WHOOP_CACHE_TTL=300
LOG_LEVEL=WARNING
